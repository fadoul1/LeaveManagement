# ============================================================
# Variables d'environnement — LeaveManagement
# 1. Copie ce fichier : cp .env.example .env
# 2. Le fichier .env est chargé automatiquement par podman compose
# 3. Ne commite JAMAIS le .env (il est dans .gitignore)
# ============================================================

# PostgreSQL
POSTGRES_DB=LeaveManagementDbDev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin

# Keycloak admin console
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# pgAdmin (interface web PostgreSQL)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
